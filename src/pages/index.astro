---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/landing.css';
import {
  NumberedCard,
  StatCard,
  FeatureCard,
  StatusDiagram,
  ComparisonCard,
  FaqAccordion,
} from '@virtuslab/visdom-ui';
import { SecurityVisdomStrip } from '../components/SecurityIslands';

const base = import.meta.env.BASE_URL;

const problemCards = [
  {
    number: "01",
    title: "Prompt Injection",
    description: "An agent reads a README and obeys it. A malicious dependency becomes an instruction channel.",
  },
  {
    number: "02",
    title: "Credential Exfiltration",
    description: "Tokens in env vars end up in logs, network requests, or a helpful commit message.",
  },
  {
    number: "03",
    title: "Supply Chain Drift",
    description: "AI reaches for the first package that compiles. Typosquats and malicious transitives slip in.",
  },
  {
    number: "04",
    title: "Vulnerable by Default",
    description: "SQLi, XSS, path traversal — classic bugs reappear at the speed of AI code generation.",
  },
];

const evidenceStats = [
  {
    value: "62%",
    label: "of 330k LLM-generated C programs contained at least one security vulnerability.",
    source: "Large-scale empirical study, 2024",
    color: "red" as const,
    href: "https://dl.acm.org/doi/10.1145/3716848",
  },
  {
    value: "28.6M",
    label: "new secrets exposed in public GitHub commits in 2025. Claude-Code-authored commits leak at ~2× the baseline rate.",
    source: "GitGuardian State of Secrets Sprawl 2026",
    color: "amber" as const,
    href: "https://www.helpnetsecurity.com/2026/04/14/gitguardian-ai-agents-credentials-leak/",
  },
  {
    value: "~20%",
    label: "of package names recommended by LLMs do not exist — \"slopsquatting\" turns those names into attacks.",
    source: "Socket / UTSA / Virginia Tech / Oklahoma, 2025",
    color: "green" as const,
    href: "https://socket.dev/blog/slopsquatting-how-ai-hallucinations-are-fueling-a-new-class-of-supply-chain-attacks",
  },
];

const pillarCards = [
  {
    label: "Runtime Containment",
    title: "Sandcat",
    description: "A Docker & dev container setup from VirtusLab for running AI agents in --dangerous mode safely. Every network call is routed through a transparent mitmproxy with allow/deny rules and secret injection at the proxy level.",
    meta: "Open source · VirtusLab",
  },
  {
    label: "Application Security",
    title: "Continuous AppSec Scanning",
    description: "Static analysis, dependency scanning, secrets detection, IaC and container checks, DAST, and runtime protection — unified and noise-reduced so findings match what the agent actually changed.",
    meta: "Partner capability · Aikido",
  },
];

const sandcatRows = [
  { label: "agent → github.com", status: "allow", variant: "success" as const },
  { label: "agent → registry.npmjs.org", status: "allow", variant: "success" as const },
  { label: "agent → paste.ee / unknown", status: "deny", variant: "danger" as const },
  { label: "SANDCAT_PLACEHOLDER_…", status: "substitute", variant: "warning" as const },
  { label: "placeholder → non-allowed host", status: "403", variant: "danger" as const },
  { label: "dns *.evil.xyz", status: "deny", variant: "danger" as const },
  { label: "tcp/udp *", status: "deny", variant: "danger" as const },
];

const aikidoCapabilities = [
  {
    abbreviation: "SAST",
    title: "Static analysis",
    description: "Scans source for SQLi, XSS, buffer overflows and custom rules — before code merges.",
  },
  {
    abbreviation: "SCA",
    title: "Open-source & supply chain",
    description: "Flags vulnerable and malicious packages, including transitive dependencies and license risks.",
  },
  {
    abbreviation: "DAST",
    title: "Dynamic & API testing",
    description: "Authenticated scans against running apps and APIs to surface runtime vulnerabilities.",
  },
  {
    abbreviation: "SECRETS",
    title: "Leaked credentials",
    description: "Detects API keys, tokens, certificates and encryption keys exposed in the repository.",
  },
  {
    abbreviation: "IaC / CSPM",
    title: "Infra & cloud posture",
    description: "Misconfigurations across Terraform, Kubernetes, container images and major cloud providers.",
  },
  {
    abbreviation: "TRIAGE",
    title: "Noise reduction",
    description: "Reachability analysis and context correlation across scanners cut alert volume dramatically.",
  },
];

const altCards = [
  {
    label: "Containment",
    title: "Sandcat vs the alternatives",
    items: [
      "Docker Sandboxes (GA Mar 2026) — per-agent microVM. Great isolation, but no transparent proxy / secret substitution.",
      "Claude Code native sandbox — OS-level FS & network rules, vendor-specific.",
      "Plain devcontainers — cheap, but no enforced egress policy or secret hygiene.",
      "Sandcat — transparent mitmproxy over WireGuard, placeholder-based secret injection, works with any tool that runs in a container.",
    ],
  },
  {
    label: "AppSec scanning",
    title: "Aikido vs the alternatives",
    items: [
      "Snyk — strongest vuln DB; no native DAST / CSPM / runtime; per-product pricing.",
      "Semgrep — fastest SAST, great rule authoring; no SCA / DAST / cloud.",
      "GitHub Advanced Security — zero-config if you already live in GitHub; narrower surface.",
      "Aikido — SAST + SCA + DAST + Secrets + IaC + CSPM + runtime under one roof, with reachability-based triage.",
    ],
  },
];

const faqItems = [
  {
    question: "Isn't running an agent in Docker already enough?",
    answer: "Docker contains the filesystem. It doesn't decide whether the agent can curl an arbitrary host or where a leaked GITHUB_TOKEN ends up. Sandcat routes every egress byte through mitmproxy with an allow/deny list and substitutes secrets at the proxy, so the value never lives inside the sandbox in the first place.",
  },
  {
    question: "We already use Copilot / Snyk / Semgrep. Why add another thing?",
    answer: "Those cover one side. Copilot writes code, SAST/SCA scans it — neither constrains what the agent can reach while it runs. Public benchmarks put 40–74% of LLM-generated code in the \"has vulnerabilities\" bucket depending on the benchmark; ~20% of package recommendations are hallucinated. The containment layer is the new requirement. Scanning is the safety net.",
  },
  {
    question: "What if the agent gets prompt-injected inside the sandbox?",
    answer: "Assume it will. CVE-2025-53773 (Copilot YOLO), CVE-2025-59944 (Cursor), Claude Cowork (Jan 2026) — all real. Sandcat's point is that a compromised agent still can't exfiltrate data to a non-allowlisted host, and still can't read the real secrets. AppSec scanning then catches whatever code it did manage to write. Defense in depth beats prompt filtering.",
  },
];

---
<BaseLayout title="Visdom Security">

  <!-- ============ Hero ============ -->
  <section class="hero">
    <div class="hero__inner">
      <h1 class="hero__headline">
        Visdom<br />
        <span class="hero__gradient">Security</span>
      </h1>
      <p class="hero__subtitle">
        Contain AI coding agents, harden what they ship.
        A sandbox for autonomous agents paired with continuous application security scanning.
      </p>
      <div class="hero__buttons">
        <a href="#sandcat" class="btn btn--primary">Sandcat Sandbox</a>
        <a href="#aikido" class="btn btn--outline">AppSec with Aikido</a>
      </div>
      <p class="hero__tagline">Part of <a href="https://virtuslab.com/services/visdom" class="hero__tagline-link">Visdom</a> &middot; VirtusLab's AI-Native SDLC</p>
    </div>
  </section>

  <div class="hazard-divider" aria-hidden="true"></div>

  <!-- ============ Problem Banner ============ -->
  <section class="problem-banner">
    <div class="problem-banner__inner">
      <h2 class="problem-banner__heading">Autonomous agents change the threat model</h2>
      <p class="problem-banner__subtitle">More code, generated faster, by actors that follow instructions literally.</p>
      <div class="problem-banner__grid">
        {problemCards.map((card) => (
          <NumberedCard
            client:load
            number={card.number}
            title={card.title}
            description={card.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============ Evidence Stats ============ -->
  <section class="evidence-strip">
    <div class="evidence-strip__inner">
      <div class="section-header-center">
        <span class="ops-kicker">Evidence log</span>
        <h2 class="section-heading">The evidence, not the vibes</h2>
      </div>
      <p class="section-subtitle">
        Why this matters, measured. Every number below links to the source.
      </p>
      <div class="evidence-strip__grid">
        {evidenceStats.map((stat) => (
          <StatCard
            client:load
            value={stat.value}
            label={stat.label}
            source={stat.source}
            color={stat.color}
            href={stat.href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============ Two Pillars ============ -->
  <section class="pillars-section">
    <div class="pillars-section__inner">
      <h2 class="section-heading">Two layers, one problem</h2>
      <p class="section-subtitle">
        Contain the agent while it writes the code. Scan what it produces before anyone deploys it.
      </p>
      <div class="pillars-grid">
        {pillarCards.map((card) => (
          <FeatureCard
            client:load
            label={card.label}
            title={card.title}
            description={card.description}
            meta={card.meta}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============ Sandcat Spotlight ============ -->
  <section class="sandcat-section" id="sandcat">
    <div class="sandcat-section__inner">
      <div class="sandcat-section__copy">
        <span class="kicker">Sandcat &middot; VirtusLab</span>
        <h2>A bulletproof cage for your agents</h2>
        <p>
          Sandcat runs AI coding agents inside a Docker sandbox and routes <strong>all</strong> container traffic
          &mdash; HTTP, HTTPS, DNS, arbitrary TCP/UDP &mdash; through a transparent mitmproxy over WireGuard.
          No per-tool proxy configuration. No tool can bypass the network boundary.
        </p>
        <p>
          An allow/deny engine decides which destinations the agent can reach. <strong>Real secrets never enter the container.</strong>
          Environment variables hold placeholders like <code>SANDCAT_PLACEHOLDER_GITHUB_TOKEN</code>; mitmproxy substitutes the
          real value only for outbound requests to allowlisted hosts &mdash; anything else is blocked with HTTP 403.
        </p>
        <p>
          WireGuard lives in a dedicated network container with <code>NET_ADMIN</code>. App containers share its network namespace
          and inherit the firewall rules, but cannot modify them. A compromised agent can neither read the secrets nor escape the tunnel.
        </p>
        <p>
          Works as a dev container or standalone. Production-validated on Java and Scala projects with Claude Code &mdash;
          the first fully sandboxed, autonomously-authored PRs are already merged into VirtusLab OSS.
        </p>
        <p>
          <a href="https://github.com/VirtusLab/sandcat" class="btn btn--outline">View on GitHub &rarr;</a>
        </p>
      </div>
      <StatusDiagram client:load rows={sandcatRows} />
    </div>
  </section>

  <!-- ============ Aikido Partner ============ -->
  <section class="partner-section" id="aikido">
    <div class="partner-section__inner">
      <div class="partner-card">
        <div class="partner-card__header">
          <span class="partner-card__logo">
            <span class="partner-card__logo-mark" aria-hidden="true"></span>
            Aikido
          </span>
          <span class="partner-card__kicker">Partner Capability</span>
        </div>
        <h3 class="partner-card__title">Code-to-runtime AppSec, unified</h3>
        <p class="partner-card__lede">
          Visdom Security complements Sandcat with a code-to-runtime security capability.
          The partner platform we integrate with &mdash; <strong>Aikido</strong> &mdash; brings every core AppSec scanner under one roof,
          deduplicates findings, and correlates them with reachability so teams act on what actually matters.
        </p>

        <div class="partner-card__grid">
          {aikidoCapabilities.map((cap) => (
            <FeatureCard
              client:load
              abbreviation={cap.abbreviation}
              title={cap.title}
              description={cap.description}
            />
          ))}
        </div>

        <p class="partner-card__note">
          Aikido is a third-party partner. Logo and product names are trademarks of their respective owners.
          Visdom Security focuses on the capability; the vendor is pluggable.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ Alternatives ============ -->
  <section class="alt-section">
    <div class="alt-section__inner">
      <div class="section-header-center">
        <span class="ops-kicker ops-kicker--light">Compare</span>
        <h2 class="section-heading">Why this combo?</h2>
      </div>
      <p class="section-subtitle">
        Good tools exist on both sides. Visdom Security is the glue &mdash; runtime containment with a mitmproxy-enforced network boundary,
        plus scanning that pays attention to what the agent actually changed.
      </p>
      <div class="alt-grid">
        {altCards.map((card) => (
          <ComparisonCard
            client:load
            label={card.label}
            title={card.title}
            items={card.items}
          />
        ))}
      </div>
      <p class="alt-section__footnote">
        Vendor is pluggable. The capability &mdash; code-to-runtime scanning with noise reduction &mdash; is the requirement.
      </p>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="faq-section">
    <div class="faq-section__inner">
      <h2 class="section-heading">FAQ</h2>
      <FaqAccordion client:load items={faqItems} />
    </div>
  </section>

  <div class="hazard-divider" aria-hidden="true"></div>

  <!-- ============ Visdom Strip ============ -->
  <SecurityVisdomStrip base={base} client:load />

  <!-- ============ CTA ============ -->
  <section class="cta-section">
    <div class="cta-section__inner">
      <h2 class="cta-section__heading">
        Ship fast.<br /><span class="hero__gradient">Stay contained.</span>
      </h2>
      <p class="cta-section__subtitle">
        Let agents move quickly inside Sandcat. Let Aikido-grade scanning decide what reaches production.
      </p>
      <div class="hero__buttons">
        <a href="https://github.com/VirtusLab/sandcat" class="btn btn--primary">Start with Sandcat</a>
        <a href="https://www.aikido.dev/" class="btn btn--outline">Explore Aikido</a>
      </div>
    </div>
  </section>

</BaseLayout>
